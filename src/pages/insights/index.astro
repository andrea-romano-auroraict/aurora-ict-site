---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.jsx";
---

<BaseLayout
  title="Insights | Aurora ICT"
  page="insights"
  description="Practical insights from Aurora ICT on technology strategy, risk reduction, and smarter IT decisions for growing businesses."
>
  <Navbar client:load />

  <main class="page-main">
    <section class="max-w-7xl mx-auto px-6 py-16 md:py-20">
      <div class="glass rounded-3xl glow p-8 md:p-10">
        <h1 class="text-4xl md:text-6xl font-extrabold text-white">Insights</h1>
        <p class="mt-4 text-lg md:text-xl" style="color: var(--muted);">
          Practical, business-focused guidance to help you reduce cost, risk, waste and complexity as you grow.
        </p>
        <p class="mt-3 text-base md:text-lg" style="color: var(--muted);">
          This is a growing library of practical articles for business leaders responsible for technology outcomes.
        </p>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 pb-24">
      <div class="grid md:grid-cols-3 gap-6">
        <article class="glass rounded-2xl glow p-7">
          <div class="text-sm font-bold" style="color: var(--color-accent-purple);">Strategy</div>
          <h2 class="text-white font-extrabold text-2xl mt-2">Signs your business has outgrown ad hoc IT decisions</h2>
          <p class="mt-3" style="color: var(--muted);">
            A practical guide for leadership teams on identifying the warning signs and moving to a more structured approach.
          </p>
          <a href="/insights/signs-your-business-has-outgrown-ad-hoc-it-decisions" class="inline-block mt-4 font-bold underline decoration-white/40 hover:decoration-white text-white">Read article</a>
        </article>

        <article class="glass rounded-2xl glow p-7">
          <div class="text-sm font-bold" style="color: var(--color-accent-purple);">Security</div>
          <h2 class="text-white font-extrabold text-2xl mt-2">Building a practical security baseline</h2>
          <p class="mt-3" style="color: var(--muted);">
            How growing organisations can strengthen resilience without creating unnecessary complexity.
          </p>
          <a href="/insights/building-a-practical-security-baseline" class="inline-block mt-4 font-bold underline decoration-white/40 hover:decoration-white text-white">Read article</a>
        </article>

        <article class="glass rounded-2xl glow p-7">
          <div class="text-sm font-bold" style="color: var(--color-accent-purple);">Technology Leadership</div>
          <h2 class="text-white font-extrabold text-2xl mt-2">From reactive IT to a clear roadmap</h2>
          <p class="mt-3" style="color: var(--muted);">
            Why business-aligned prioritisation improves execution, reduces rework and supports better investment decisions.
          </p>
          <a href="/insights/from-reactive-it-to-a-clear-roadmap" class="inline-block mt-4 font-bold underline decoration-white/40 hover:decoration-white text-white">Read article</a>
        </article>
      </div>

      <div class="mt-10">
        <a href="/contact"
           class="inline-flex items-center justify-center px-8 py-4 rounded-xl font-extrabold transition hover:brightness-110"
           style="background: var(--color-accent-green); color: #08110c; box-shadow: 0 0 22px rgba(57,255,122,0.22);">
          Book a free initial consultation
        </a>
        <div class="mt-4 flex flex-wrap gap-4 text-sm md:text-base">
          <a href="/services" class="font-bold underline decoration-white/30 hover:decoration-white text-white">Explore services</a>
          <a href="/technology-health-check" class="font-bold underline decoration-white/30 hover:decoration-white text-white">Technology Health Check</a>
          <a href="/it-strategy-roadmap" class="font-bold underline decoration-white/30 hover:decoration-white text-white">IT Strategy Roadmap</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
