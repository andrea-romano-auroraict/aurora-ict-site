---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.jsx";
import HubSpotContactForm from "../components/HubSpotContactForm.astro";
---

<BaseLayout
  title="Contact"
  page="contact"
  description="Contact our Brisbane and Queensland IT team for small and medium businesses and book a free initial consultation."
>
  <Navbar client:load />

  <main class="page-main">
    <section class="max-w-7xl mx-auto px-6 py-16 md:py-20">
      <div class="glass rounded-3xl glow p-8 md:p-10">
        <h1 class="text-4xl md:text-6xl font-extrabold text-white">Book a free initial consultation</h1>
        <p class="mt-4 text-lg md:text-xl" style="color: var(--muted);">
          Start with a practical, low-friction conversation about your systems, costs, risks, and priorities.
          If you are still weighing options after reviewing our <a href="/services" class="underline decoration-white/30 hover:decoration-white text-white">services</a> or
          <a href="/insights" class="underline decoration-white/30 hover:decoration-white text-white">insights</a>, Aurora ICT will help identify the right
          starting point — often a <a href="/technology-health-check" class="underline decoration-white/30 hover:decoration-white text-white">Technology Health Check</a>,
          a roadmap discussion, or targeted advisory support.
        </p>

        <div class="mt-8">
          <HubSpotContactForm
            region="ap1"
            portalId="442798078"
            formId="b3b7df85-002d-43bd-aac2-439175a8e64c"
          />
        </div>

        <div class="mt-4 flex flex-col sm:flex-row gap-4">
          <a
            href="/services"
            class="inline-flex items-center justify-center px-6 py-3 rounded-xl font-bold border border-white/15 bg-white/10 hover:bg-white/15 transition text-white"
          >
            View services
          </a>
        </div>

        <div class="mt-6 text-sm" style="color: var(--muted);">
          Brisbane / QLD • Remote Australia-wide
        </div>
        <p class="mt-3 text-sm" style="color: var(--muted);">
          Share your main challenge and preferred timing, and our team will respond with practical next steps.
        </p>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 pb-24 grid md:grid-cols-2 gap-6">
      <div class="glass rounded-2xl glow p-8">
        <h2 class="text-white font-extrabold text-3xl">What to expect</h2>
        <ul class="mt-4 list-disc pl-5 space-y-2" style="color: var(--muted);">
          <li>We acknowledge your enquiry and confirm scope and timing.</li>
          <li>A focused discussion about your current situation and business goals.</li>
          <li>Initial guidance on priorities, risks, and practical options.</li>
          <li>A clear recommendation on the best next step, with no pressure to over-commit.</li>
        </ul>
      </div>

      <div class="glass rounded-2xl glow p-8">
        <h2 class="text-white font-extrabold text-3xl">Useful context to include</h2>
        <ul class="mt-4 list-disc pl-5 space-y-2" style="color: var(--muted);">
          <li>Your business size and location.</li>
          <li>Your current systems, tools, or vendors.</li>
          <li>The main issue or priority you want to address.</li>
          <li>Any timeline, project, or risk concern already in play.</li>
          <li>Whether you want strategic direction, implementation support, or both.</li>
        </ul>
      </div>
    </section>
  </main>
</BaseLayout>
