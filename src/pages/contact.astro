---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.jsx";
---

<BaseLayout
  title="Contact"
  page="contact"
  description="Contact our Brisbane and Queensland IT team for small and medium businesses and book a free initial consultation."
>
  <Navbar client:load />

  <main class="page-main">
    <section class="max-w-7xl mx-auto px-6 py-16 md:py-20">
      <div class="glass rounded-3xl glow p-8 md:p-10">
        <h1 class="text-4xl md:text-6xl font-extrabold text-white">Book a free initial consultation</h1>
        <p class="mt-4 text-lg md:text-xl" style="color: var(--muted);">
          Start with a practical conversation about your current systems, costs, risks, and priorities. Aurora ICT will
          help you identify the most useful next step — whether that is a <a href="/technology-health-check" class="underline decoration-white/30 hover:decoration-white text-white">Technology Health Check</a>, a roadmap discussion,
          or targeted advisory support.
        </p>

        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a
            href="mailto:hello@auroraict.com.au?subject=Enquiry%20-%20Aurora%20ICT"
            class="inline-flex items-center justify-center px-6 py-3 rounded-xl font-extrabold transition hover:brightness-110"
            style="background: var(--color-accent-green); color: #08110c; box-shadow: 0 0 22px rgba(57,255,122,0.22);"
            data-ga-email-lead
          >
            Email Aurora ICT
          </a>

          <a
            href="/services"
            class="inline-flex items-center justify-center px-6 py-3 rounded-xl font-bold border border-white/15 bg-white/10 hover:bg-white/15 transition text-white"
          >
            View services
          </a>
        </div>

        <div class="mt-6 text-sm" style="color: var(--muted);">
          Brisbane / QLD • Remote Australia-wide
        </div>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 pb-24 grid md:grid-cols-2 gap-6">
      <div class="glass rounded-2xl glow p-8">
        <h2 class="text-white font-extrabold text-3xl">What to expect</h2>
        <ul class="mt-4 list-disc pl-5 space-y-2" style="color: var(--muted);">
          <li>A focused discussion about your current situation</li>
          <li>Initial guidance on priorities, risks, and opportunities</li>
          <li>A clear recommendation on the best next step</li>
          <li>No pressure to commit beyond what is useful</li>
        </ul>
      </div>

      <div class="glass rounded-2xl glow p-8">
        <h2 class="text-white font-extrabold text-3xl">Helpful details to share</h2>
        <ul class="mt-4 list-disc pl-5 space-y-2" style="color: var(--muted);">
          <li>Your business size and location</li>
          <li>Your current systems, tools, or vendors</li>
          <li>The main issue or priority you want to address</li>
          <li>Any timeline, project, or risk concern already in play</li>
        </ul>
      </div>
    </section>
  </main>
</BaseLayout>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll("[data-ga-email-lead]").forEach((el) => {
      el.addEventListener("click", (e) => {
        if (typeof window === "undefined") return;

        e.preventDefault(); // pause mailto briefly so GA can send

        const payload = {
          event_category: "contact",
          event_label: "mailto",
          transport_type: "beacon",
          non_interaction: true,
          page_path: window.location.pathname,
        };

        // Always use gtag-style dataLayer push (works even if window.gtag is missing)
        window.dataLayer = window.dataLayer || [];
        const gtagSafe =
          typeof window.gtag === "function"
            ? window.gtag
            : function () {
                window.dataLayer.push(arguments);
              };

        gtagSafe("event", "email_lead", payload);

        // Let GA send, then open mail client
        setTimeout(() => {
          window.location.href = el.getAttribute("href");
        }, 150);
      });
    });
  });
</script>
