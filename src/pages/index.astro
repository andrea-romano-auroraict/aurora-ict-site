---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.jsx";
---

<BaseLayout
  title="IT Consulting Brisbane | IT Consultant & Virtual CTO | Aurora ICT"
  page="home"
  description="Aurora ICT provides IT consulting in Brisbane, IT consultant services, and virtual CTO support for growing businesses that want to reduce technology risk, simplify systems and vendors, and plan with more confidence."
>
  <Navbar client:load />

  <main class="page-main">

    <!-- HERO -->
    <section class="max-w-7xl mx-auto px-6 py-16 md:py-24">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div class="glass rounded-3xl glow p-8 md:p-10">
<div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-white/12 border border-white/20">
  <span class="h-3 w-3 rounded-full" style="background: var(--color-accent-green); box-shadow: 0 0 18px rgba(57,255,122,0.45);"></span>
  <span class="text-base md:text-lg font-extrabold tracking-wide text-white">
    AI-powered IT services
  </span>
  <span class="hidden md:inline text-sm font-semibold px-3 py-1 rounded-full"
        style="background: rgba(124,58,237,0.20); border: 1px solid rgba(124,58,237,0.35); color: rgba(231,238,252,0.95);">
    Strategy • Security • Cloud • Delivery
  </span>
</div>

<p class="mt-5 text-sm md:text-base font-bold tracking-wide uppercase" style="color: var(--color-accent-purple);">
  Virtual CTO / IT Consultant for growing businesses
</p>

<h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight mt-5">
  Lower technology costs, reduce risk, and simplify IT tools and vendors
</h1>

          <p class="text-lg md:text-xl mt-5" style="color: var(--muted);">
            Aurora ICT provides IT consulting in Brisbane, combining IT consultant services and virtual CTO support to help growing businesses simplify technology, reduce risk, and lead with more confidence.
          </p>

          <div class="mt-8 flex flex-col sm:flex-row gap-4">
            <a
              href="/contact"
              class="inline-flex items-center justify-center px-6 py-3 rounded-xl font-extrabold transition hover:brightness-110"
              style="background: var(--color-accent-green); color: #08110c; box-shadow: 0 0 22px rgba(57,255,122,0.22);"
            >
              Book a free initial consultation
            </a>

            <a
              href="/services"
              class="inline-flex items-center justify-center px-6 py-3 rounded-xl font-bold border border-white/15 bg-white/10 hover:bg-white/15 transition text-white"
            >
              Explore services
            </a>
          </div>

          <div class="mt-6 text-sm" style="color: var(--muted);">
            Brisbane &amp; South East Queensland focus • Australia-wide support
          </div>
        </div>

        <!-- Hero Visual -->
        <div class="glass rounded-3xl glow p-8 md:p-10 min-h-[320px] flex items-center justify-center text-center">
          <div>
            <div class="text-white text-2xl md:text-3xl font-extrabold">
              Technology leadership, without full-time cost
            </div>
            <div class="mt-3 text-base md:text-lg" style="color: var(--muted);">
              Roadmaps • Governance • Delivery • Security • AI enablement
            </div>

            <div class="mt-8 grid grid-cols-2 gap-3 text-sm">
              <div class="rounded-xl bg-white/10 border border-white/15 px-4 py-3 text-white">Fast discovery</div>
              <div class="rounded-xl bg-white/10 border border-white/15 px-4 py-3 text-white">Clear priorities</div>
              <div class="rounded-xl bg-white/10 border border-white/15 px-4 py-3 text-white">Reduced risk</div>
              <div class="rounded-xl bg-white/10 border border-white/15 px-4 py-3 text-white">Measured outcomes</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- TRUST STRIP -->
    <section class="max-w-7xl mx-auto px-6 pb-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="glass rounded-2xl p-5 text-center">
          <div class="text-white font-extrabold text-lg">Lower Costs</div>
          <div class="text-sm mt-1" style="color: var(--muted);">Less waste across tools</div>
        </div>
        <div class="glass rounded-2xl p-5 text-center">
          <div class="text-white font-extrabold text-lg">Reduce Risk</div>
          <div class="text-sm mt-1" style="color: var(--muted);">Practical controls and clarity</div>
        </div>
        <div class="glass rounded-2xl p-5 text-center">
          <div class="text-white font-extrabold text-lg">Integrate IT</div>
          <div class="text-sm mt-1" style="color: var(--muted);">Simpler tools and vendors</div>
        </div>
        <div class="glass rounded-2xl p-5 text-center">
          <div class="text-white font-extrabold text-lg">Lead with Confidence</div>
          <div class="text-sm mt-1" style="color: var(--muted);">Manage technology with direction</div>
        </div>
      </div>
    </section>

    <!-- WHO WE HELP -->
    <section class="max-w-7xl mx-auto px-6 py-12">
      <div class="glass rounded-3xl glow p-8 md:p-10">
        <h2 class="text-3xl md:text-4xl font-extrabold text-white">Who Aurora ICT helps</h2>
        <p class="mt-4 text-lg" style="color: var(--muted);">
          Aurora ICT works with growing businesses in Brisbane and South East Queensland that need clearer technology direction without the cost of a full-time CTO.
        </p>
        <p class="mt-5 text-base md:text-lg font-bold text-white">
          We are best suited to businesses that:
        </p>
        <ul class="mt-4 space-y-3 text-base md:text-lg list-disc list-inside" style="color: var(--muted);">
          <li>are growing and relying on more systems, tools, and vendors</li>
          <li>need to lower technology costs and reduce waste</li>
          <li>want stronger oversight of IT decisions, risks, and priorities</li>
          <li>are dealing with increasing operational or cybersecurity risk</li>
          <li>need technology simplified into something non-technical leaders can manage with confidence</li>
        </ul>
      </div>
    </section>

    <!-- PROBLEMS WE SOLVE -->
    <section class="max-w-7xl mx-auto px-6 pb-12">
      <div class="glass rounded-3xl glow p-8 md:p-10">
        <h2 class="text-3xl md:text-4xl font-extrabold text-white">Problems Aurora ICT solves</h2>
        <p class="mt-4 text-lg" style="color: var(--muted);">
          Aurora ICT helps growing businesses take control of technology before cost, complexity, and risk start slowing the business down.
        </p>
        <ul class="mt-5 space-y-3 text-base md:text-lg list-disc list-inside" style="color: var(--muted);">
          <li>technology costs are rising without clear value</li>
          <li>systems and processes are no longer keeping up with growth</li>
          <li>technology decisions are being made reactively instead of strategically</li>
          <li>tools and vendors have grown without clear ownership</li>
          <li>cybersecurity and operational risk are increasing</li>
          <li>projects and change initiatives lack structure and oversight</li>
        </ul>
      </div>
    </section>

    <!-- HEALTH CHECK CTA -->
    <section class="max-w-7xl mx-auto px-6 pb-12">
      <div class="glass rounded-3xl glow p-8 md:p-10">
        <h2 class="text-3xl md:text-4xl font-extrabold text-white">Start with a <a href="/technology-health-check" class="underline decoration-white/30 hover:decoration-white text-white">Technology Health Check</a></h2>
        <p class="mt-4 text-lg" style="color: var(--muted);">
          A focused first step to identify technology waste, unnecessary complexity, key risks, and the highest-priority actions for your business. <a href="/technology-health-check" class="underline decoration-white/30 hover:decoration-white text-white">See how the Health Check works.</a>
        </p>
        <ul class="mt-5 space-y-3 text-base md:text-lg list-disc list-inside" style="color: var(--muted);">
          <li>identify quick wins and cost-saving opportunities</li>
          <li>highlight risks, gaps, and inefficiencies</li>
          <li>clarify priorities for the next 90 days</li>
          <li>create a practical basis for stronger technology decisions</li>
        </ul>
        <div class="mt-7">
          <a
            href="/contact"
            class="inline-flex items-center justify-center px-6 py-3 rounded-xl font-extrabold transition hover:brightness-110"
            style="background: var(--color-accent-green); color: #08110c; box-shadow: 0 0 22px rgba(57,255,122,0.22);"
          >
            Book a free initial consultation
          </a>
        </div>
      </div>
    </section>


    <!-- WHY AURORA ICT -->
    <section class="max-w-7xl mx-auto px-6 pb-12">
      <div class="glass rounded-3xl glow p-8 md:p-10">
        <h2 class="text-3xl md:text-4xl font-extrabold text-white">Why Aurora ICT</h2>
        <p class="mt-4 text-lg" style="color: var(--muted);">
          Aurora ICT provides independent, business-focused technology advice designed to lower costs, reduce risk, and simplify technology without pushing unnecessary tools, projects, or long-term dependency.
        </p>
        <ul class="mt-5 space-y-3 text-base md:text-lg list-disc list-inside" style="color: var(--muted);">
          <li>practical advice grounded in business priorities</li>
          <li>focused on simplifying technology for non-technical decision-makers</li>
          <li>modular support that can stop at any stage</li>
          <li>aligned to clearer ownership, stronger oversight, and lower waste</li>
        </ul>
      </div>
    </section>

    <!-- SERVICES PREVIEW -->
    <section class="max-w-7xl mx-auto px-6 py-16">
      <div class="flex items-end justify-between gap-6 mb-10">
        <div>
          <h2 class="text-3xl md:text-4xl font-extrabold text-white">How We Help</h2>
          <p class="mt-2 text-lg" style="color: var(--muted);">
            Senior guidance to simplify decisions, improve security, and deliver outcomes with confidence. Learn more about our <a href="/it-consulting-brisbane" class="underline decoration-white/30 hover:decoration-white text-white">IT consulting Brisbane services</a>.
          </p>
        </div>
        <a href="/services"
           class="hidden sm:inline-flex items-center justify-center px-5 py-3 rounded-xl font-bold border border-white/15 bg-white/10 hover:bg-white/15 transition text-white">
          Explore services
        </a>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="glass rounded-2xl glow p-6 hover:bg-white/10 transition">
          <div class="text-sm font-bold" style="color: var(--color-accent-purple);">Fractional leadership</div>
          <h3 class="text-white font-extrabold text-xl mt-2">Virtual CTO</h3>
          <p class="mt-2" style="color: var(--muted);">
            Executive-level leadership without a full-time hire—strategy, governance, prioritisation.
          </p>
        </div>

        <div class="glass rounded-2xl glow p-6 hover:bg-white/10 transition">
          <div class="text-sm font-bold" style="color: var(--color-accent-purple);">Scalable foundations</div>
          <h3 class="text-white font-extrabold text-xl mt-2">Cloud & Architecture</h3>
          <p class="mt-2" style="color: var(--muted);">
            Modern, secure platforms designed for reliability, cost control, and growth.
          </p>
        </div>

        <div class="glass rounded-2xl glow p-6 hover:bg-white/10 transition">
          <div class="text-sm font-bold" style="color: var(--color-accent-purple);">Risk & resilience</div>
          <h3 class="text-white font-extrabold text-xl mt-2">Cyber Risk Reduction</h3>
          <p class="mt-2" style="color: var(--muted);">
            Practical security uplift—MFA, access control, backups, logging, and readiness.
          </p>
        </div>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 pb-12">
      <div class="glass rounded-3xl glow p-8 md:p-10">
        <div class="text-sm font-bold" style="color: var(--color-accent-purple);">Featured offer</div>
        <h2 class="text-3xl md:text-4xl font-extrabold text-white mt-2">Aurora ICT Total Care for growing businesses</h2>
        <p class="mt-4 text-lg" style="color: var(--muted);">
          Planning, leadership and practical IT service in one tailored model. Aurora ICT Total Care gives growing businesses worry-free technology support, senior guidance and independent advice without MSP lock-in or one-size-fits-all packages.
        </p>
        <p class="mt-3 text-base md:text-lg" style="color: var(--muted);">
          Aurora ICT is not an MSP — it is an independent technology partner for growing businesses that need planning, leadership and practical IT service.
        </p>
        <div class="mt-6">
          <a
            href="/it-support-and-fractional-cto/"
            class="inline-flex items-center justify-center px-6 py-3 rounded-xl font-extrabold transition hover:brightness-110"
            style="background: var(--color-accent-green); color: #08110c; box-shadow: 0 0 22px rgba(57,255,122,0.22);"
          >
            Explore Aurora ICT Total Care
          </a>
        </div>
      </div>
    </section>


    <section class="max-w-7xl mx-auto px-6 pb-16">
      <div class="glass rounded-3xl glow p-8 md:p-10">
        <h2 class="text-3xl md:text-4xl font-extrabold text-white">Plan Your IT Future</h2>
        <p class="mt-4 text-lg" style="color: var(--muted);">
          1-year, 3-year and 5-year technology roadmaps built from a full assessment of your infrastructure, platforms and cybersecurity—tailored to your goals and constraints.
        </p>
        <div class="mt-6 flex flex-wrap gap-4">
          <a
            href="/it-strategy-roadmap"
            class="inline-flex items-center justify-center px-6 py-3 rounded-xl font-extrabold transition hover:brightness-110"
            style="background: var(--color-accent-green); color: #08110c; box-shadow: 0 0 22px rgba(57,255,122,0.22);"
          >
            Explore IT Roadmap
          </a>
          <a
            href="/contact"
            class="inline-flex items-center justify-center px-6 py-3 rounded-xl font-bold border border-white/15 bg-white/10 hover:bg-white/15 transition text-white"
          >
            Contact Aurora ICT
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="max-w-7xl mx-auto px-6 pb-12">
      <div class="glass rounded-3xl glow p-8 md:p-10">
        <h2 class="text-3xl md:text-4xl font-extrabold text-white">Frequently asked questions</h2>
        <div class="mt-6 space-y-5">
          <article>
            <h3 class="text-white font-extrabold text-xl">What does an IT consultant in Brisbane help with?</h3>
            <p class="mt-2" style="color: var(--muted);">
              Aurora ICT helps growing businesses set priorities, simplify systems and vendors, reduce risk, and make clearer technology decisions that support business goals. Explore <a href="/it-support-and-fractional-cto" class="underline decoration-white/30 hover:decoration-white text-white">Aurora ICT Total Care</a> for IT support and technology leadership in one tailored model.
            </p>
          </article>
          <article>
            <h3 class="text-white font-extrabold text-xl">When does a business need a virtual CTO?</h3>
            <p class="mt-2" style="color: var(--muted);">
              A virtual CTO is useful when technology complexity is growing and leadership needs senior guidance, but a full-time CTO is not yet required.
            </p>
          </article>
          <article>
            <h3 class="text-white font-extrabold text-xl">How can Aurora ICT help reduce technology costs and risk?</h3>
            <p class="mt-2" style="color: var(--muted);">
              We identify waste, prioritise practical improvements, strengthen governance and cybersecurity controls, and provide a staged plan that balances cost, risk, and delivery.
            </p>
          </article>
          <article>
            <h3 class="text-white font-extrabold text-xl">Do you only work with Brisbane businesses?</h3>
            <p class="mt-2" style="color: var(--muted);">
              Brisbane and South East Queensland are our core focus, and we also support growing businesses across Australia remotely.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- PROCESS -->
    <section class="max-w-7xl mx-auto px-6 pb-20">
      <div class="glass rounded-3xl glow p-8 md:p-10">
        <h2 class="text-3xl md:text-4xl font-extrabold text-white">Our Approach</h2>
        <p class="mt-2 text-lg" style="color: var(--muted);">
          A simple process that keeps priorities clear and delivery predictable.
        </p>

        <div class="grid md:grid-cols-4 gap-6 mt-10">
          <div class="rounded-2xl bg-white/10 border border-white/15 p-6">
            <div class="text-4xl font-extrabold" style="color: var(--color-accent-green);">1</div>
            <div class="text-white font-extrabold text-lg mt-2">Discover</div>
            <div class="mt-2" style="color: var(--muted);">Goals, risks, constraints, and quick wins.</div>
          </div>
          <div class="rounded-2xl bg-white/10 border border-white/15 p-6">
            <div class="text-4xl font-extrabold" style="color: var(--color-accent-green);">2</div>
            <div class="text-white font-extrabold text-lg mt-2">Plan</div>
            <div class="mt-2" style="color: var(--muted);">A realistic roadmap with milestones and owners.</div>
          </div>
          <div class="rounded-2xl bg-white/10 border border-white/15 p-6">
            <div class="text-4xl font-extrabold" style="color: var(--color-accent-green);">3</div>
            <div class="text-white font-extrabold text-lg mt-2">Execute</div>
            <div class="mt-2" style="color: var(--muted);">Govern delivery and vendor performance.</div>
          </div>
          <div class="rounded-2xl bg-white/10 border border-white/15 p-6">
            <div class="text-4xl font-extrabold" style="color: var(--color-accent-green);">4</div>
            <div class="text-white font-extrabold text-lg mt-2">Improve</div>
            <div class="mt-2" style="color: var(--muted);">Measure outcomes and optimise continuously.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="max-w-7xl mx-auto px-6 pb-24 text-center">
      <div class="glass rounded-3xl glow p-10 md:p-14">
        <h2 class="text-3xl md:text-5xl font-extrabold text-white">
          Let’s make your technology simpler, safer, and more effective
        </h2>
        <p class="mt-4 text-lg md:text-xl" style="color: var(--muted);">
          Book a quick call and we’ll suggest practical next steps—no pressure, just clarity.
        </p>

        <a
          href="/contact"
          class="mt-8 inline-flex items-center justify-center px-8 py-4 rounded-xl font-extrabold transition hover:brightness-110"
          style="background: var(--color-accent-green); color: #08110c; box-shadow: 0 0 22px rgba(57,255,122,0.22);"
        >
          Book a free consult
        </a>
      </div>
    </section>

  </main>
</BaseLayout>
