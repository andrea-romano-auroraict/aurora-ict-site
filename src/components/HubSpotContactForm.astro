---
interface Props {
  region: string;
  portalId: string;
  formId: string;
}

const { region, portalId, formId } = Astro.props;
const targetId = `hubspot-form-${formId}`;
---

<div class="aurora-hubspot-form">
  <div id={targetId} class="aurora-hubspot-form__target" aria-live="polite"></div>

  <noscript>
    <p class="hubspot-noscript">Please enable JavaScript to load the contact form.</p>
  </noscript>
</div>

<script is:inline define:vars={{ region, portalId, formId, targetId }}>
  (() => {
    const target = document.getElementById(targetId);
    const firedSubmissionKeys = new Set();

    if (!target) return;

    const getSubmissionKey = (payload) => {
      const candidates = [
        payload?.submissionId,
        payload?.conversionId,
        payload?.submittedAt,
        payload?.timestamp,
      ];

      const firstDefined = candidates.find((value) => value !== undefined && value !== null);
      return firstDefined ? String(firstDefined) : "single-page-view";
    };

    const trackLeadSubmission = (submissionPayload = {}) => {
      const submissionKey = getSubmissionKey(submissionPayload);
      if (firedSubmissionKeys.has(submissionKey)) return;
      firedSubmissionKeys.add(submissionKey);

      const payload = {
        form_name: "contact",
        lead_type: "website_contact",
        page_location: window.location.href,
        page_title: document.title,
      };

      window.dataLayer = window.dataLayer || [];
      const gtagSafe =
        typeof window.gtag === "function"
          ? window.gtag
          : function () {
              window.dataLayer.push(arguments);
            };

      gtagSafe("event", "generate_lead", payload);
      gtagSafe("event", "email_lead", payload);
    };

    const bindSubmissionMessageListener = () => {
      window.addEventListener("message", (event) => {
        const payload = event.data;
        if (!payload || payload.type !== "hsFormCallback") return;
        if (payload.eventName !== "onFormSubmitted") return;

        const matchesFormId = !payload.id || payload.id === formId;
        const matchesPortalId =
          !payload.portalId || String(payload.portalId) === String(portalId);
        if (!matchesFormId || !matchesPortalId) return;

        trackLeadSubmission(payload.data || {});
      });
    };

    const createForm = () => {
      if (!window.hbspt?.forms?.create) return false;
      if (target.dataset.hsFormRendered === "true") return true;

      window.hbspt.forms.create({
        region,
        portalId,
        formId,
        target: `#${targetId}`,
        onFormSubmitted: (_form, submissionData) => {
          trackLeadSubmission(submissionData || {});
        },
      });

      target.dataset.hsFormRendered = "true";
      return true;
    };

    bindSubmissionMessageListener();

    const scriptId = `hs-form-script-${portalId}`;
    let script = document.getElementById(scriptId);

    if (!script) {
      script = document.createElement("script");
      script.id = scriptId;
      script.src = `https://js-${region}.hsforms.net/forms/embed/${portalId}.js`;
      script.defer = true;
      document.head.appendChild(script);
    }

    const tryRender = () => {
      if (createForm()) {
        return true;
      }
      return false;
    };

    if (tryRender()) return;

    script.addEventListener("load", tryRender, { once: true });

    const poll = window.setInterval(() => {
      if (tryRender()) {
        window.clearInterval(poll);
      }
    }, 250);

    window.setTimeout(() => window.clearInterval(poll), 10000);
  })();
</script>

<style>
  .aurora-hubspot-form {
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 1rem;
    background: rgba(5, 9, 24, 0.86);
    padding: 1.25rem;
  }

  .aurora-hubspot-form__target {
    width: 100%;
  }

  .hubspot-noscript {
    color: rgba(231, 238, 252, 0.9);
    margin: 0;
    font-size: 0.95rem;
  }

  :global(.aurora-hubspot-form .hs-form) {
    display: grid;
    gap: 1rem;
    margin: 0;
    font-family: "Source Sans 3", system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
  }

  :global(.aurora-hubspot-form .hs-form fieldset) {
    max-width: none;
    display: grid;
    gap: 1rem;
    width: 100%;
  }

  :global(.aurora-hubspot-form .hs-form .hs-form-field) {
    margin-bottom: 0;
  }

  :global(.aurora-hubspot-form .hs-form-field > label),
  :global(.aurora-hubspot-form .hs-richtext),
  :global(.aurora-hubspot-form .hs-form label) {
    color: #eaf1ff;
    font-size: 0.97rem;
    font-weight: 700;
    line-height: 1.45;
    margin-bottom: 0.4rem;
  }

  :global(.aurora-hubspot-form .hs-input),
  :global(.aurora-hubspot-form .hs-form textarea),
  :global(.aurora-hubspot-form .hs-form select) {
    width: 100%;
    border-radius: 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.24);
    background: rgba(7, 12, 32, 0.92);
    color: #e7eefc;
    min-height: 2.95rem;
    padding: 0.75rem 0.9rem;
    box-shadow: inset 0 1px 1px rgba(0, 0, 0, 0.32);
    transition: border-color 140ms ease, box-shadow 140ms ease, background-color 140ms ease;
  }

  :global(.aurora-hubspot-form .hs-form textarea) {
    min-height: 7.5rem;
  }

  :global(.aurora-hubspot-form .hs-input::placeholder),
  :global(.aurora-hubspot-form .hs-form textarea::placeholder) {
    color: rgba(231, 238, 252, 0.66);
  }

  :global(.aurora-hubspot-form .hs-input:focus),
  :global(.aurora-hubspot-form .hs-form textarea:focus),
  :global(.aurora-hubspot-form .hs-form select:focus) {
    outline: none;
    border-color: rgba(57, 255, 122, 0.85);
    box-shadow: 0 0 0 3px rgba(57, 255, 122, 0.2);
    background: rgba(11, 16, 39, 0.98);
  }

  :global(.aurora-hubspot-form .hs-error-msg),
  :global(.aurora-hubspot-form .hs-main-font-element) {
    color: #ffc4c4;
  }

  :global(.aurora-hubspot-form .hs-submit) {
    margin-top: 0.45rem;
    display: flex;
    justify-content: flex-start;
    width: 100%;
  }

  :global(.aurora-hubspot-form .hs-button) {
    appearance: none;
    border: none;
    border-radius: 0.75rem;
    background: var(--color-accent-green);
    color: #07130c;
    padding: 0.85rem 1.35rem;
    font-weight: 800;
    font-family: "Inter", system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
    font-size: 1rem;
    line-height: 1;
    min-height: 2.95rem;
    box-shadow: 0 0 22px rgba(57, 255, 122, 0.22);
    transition: filter 140ms ease, transform 140ms ease;
    text-shadow: none;
  }

  :global(.aurora-hubspot-form .hs-button:hover) {
    filter: brightness(1.08);
  }

  :global(.aurora-hubspot-form .hs-button:active) {
    transform: translateY(1px);
  }

  :global(.aurora-hubspot-form .submitted-message) {
    color: rgba(231, 238, 252, 0.98);
    background: rgba(57, 255, 122, 0.1);
    border: 1px solid rgba(57, 255, 122, 0.3);
    border-radius: 0.75rem;
    padding: 0.85rem;
  }

  :global(.aurora-hubspot-form .hs-form__virality-link),
  :global(.aurora-hubspot-form .hs-form .hs-form-virality-link) {
    display: none !important;
  }

  @media (max-width: 767px) {
    :global(.aurora-hubspot-form .hs-submit .actions),
    :global(.aurora-hubspot-form .hs-submit .hs-button) {
      width: 100%;
    }
  }

  @media (min-width: 768px) {
    .aurora-hubspot-form {
      padding: 1.5rem;
    }
  }
</style>
